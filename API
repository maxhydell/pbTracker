// ===== SCHEDULE =====
function getSchedule() {
  const sheet = SpreadsheetApp.openById(SPREADSHEET_ID)
    .getSheetByName(SHEET_SCHEDULE);

  const data = sheet.getDataRange().getValues();

const tz = Session.getScriptTimeZone();

const now = new Date();
const today = new Date(
  Utilities.formatDate(now, tz, "yyyy-MM-dd") + "T00:00:00"
);
const day = today.getDay();

// ✅ Sat (6) + Sun (0) → next week
const diffToMonday =
  (day === 0 || day === 6)
    ? (day === 0 ? 1 : 2) // Sun→+1, Sat→+2
    : 1 - day;

  const monday = new Date(today);
  monday.setDate(today.getDate() + diffToMonday);
  monday.setHours(0,0,0,0);

  const friday = new Date(monday);
  friday.setDate(monday.getDate() + 4);
  friday.setHours(0,0,0,0); // 🔥 ADD

  Logger.log("📅 WEEK RANGE:");
  Logger.log("Monday: " + monday);
  Logger.log("Friday: " + friday);

  const filtered = data.slice(1).filter(r => {
    const d = new Date(r[0]);
    if (isNaN(d)) return false;

    d.setHours(0,0,0,0);

    return d.getTime() >= monday.getTime() &&
       d.getTime() <= friday.getTime();
  });

  Logger.log("✅ FILTERED ROWS: " + filtered.length);

  const days = [];
  for (let i = 0; i < 5; i++) {
    const d = new Date(monday);
    d.setDate(monday.getDate() + i);

  const found = filtered.find(r => {
  const rd = new Date(r[0]);
  rd.setHours(0,0,0,0);

  const dd = new Date(d);
  dd.setHours(0,0,0,0);

  return rd.getTime() === dd.getTime();
});

if (found) {
  days.push({
    date: Utilities.formatDate(
      new Date(found[0]),
      Session.getScriptTimeZone(),
      "yyyy-MM-dd"
    ),

    // 🔥 force lowercase consistency
    players: found.slice(2, 6).map(p =>
      (p || "").toString().toLowerCase()
    ),

    // 🔥 FIX: correct columns + force numbers
    status: found.slice(7, 11).map(n => Number(n) || 0)
  });
} else {
  days.push({
    date: Utilities.formatDate(
      d,
      Session.getScriptTimeZone(),
      "yyyy-MM-dd"
    ),
    players: ["", "", "", ""],
    status: [0,0,0,0]
    });
  }
}

return days;
}

