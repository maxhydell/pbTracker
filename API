function saveHistory() {

  const ss = SpreadsheetApp.openById(SPREADSHEET_ID);
  const rankings = ss.getSheetByName("Rankings");
  const history = ss.getSheetByName("History");
  const todayStr = new Date().toDateString();

  const props = PropertiesService.getScriptProperties();
  const key = "history_" + todayStr;

  if (props.getProperty(key)) {
    return { skipped: true };
  }

  props.setProperty(key, "1");

  const data = rankings.getDataRange().getValues();
  const rows = [];

  data.slice(1).forEach(r => {
    if (!r[0]) return;

    const games = Number(r[5]) || 0;
    if (games === 0) return;

    rows.push([
      new Date(),
      r[0],
      Number(r[6]) || 0,
      Number(r[7]) || 0
    ]);
  });

  if (rows.length) {
    history.getRange(history.getLastRow() + 1, 1, rows.length, rows[0].length)
           .setValues(rows);
  }

  return { success: true };
}




