function updatePlayerStats(player, winsDelta, pointsDelta, gamesDelta) {
  const sheet = SpreadsheetApp.openById(SPREADSHEET_ID)
    .getSheetByName("Rankings");

  const data = sheet.getDataRange().getValues();

  const target = player.trim().toLowerCase();
  let found = false;

  for (let r = 1; r < data.length; r++) {
    const name = (data[r][0] || "").trim().toLowerCase();

    if (name === target) {
      found = true;

      const currentWins = Number(data[r][3]) || 0;
      const currentPoints = Number(data[r][4]) || 0;
      const currentGames = Number(data[r][5]) || 0;

      sheet.getRange(r + 1, 4).setValue(Math.max(0, currentWins + winsDelta));
      sheet.getRange(r + 1, 5).setValue(Math.max(0, currentPoints + pointsDelta));
      sheet.getRange(r + 1, 6).setValue(Math.max(0, currentGames + gamesDelta));

      break;
    }
  }

  if (!found) {
    Logger.log("❌ PLAYER NOT FOUND IN RANKINGS:", player);
  }
}


