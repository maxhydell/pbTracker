function updateSchedule(data) {
  const sheet = SpreadsheetApp.openById(SPREADSHEET_ID)
    .getSheetByName("Schedule");

  const date = data.date;
  const col = Math.max(3, Math.min(6, Number(data.col))); // 3–6
  const name = data.name;

  const values = sheet.getDataRange().getValues();

  for (let i = 1; i < values.length; i++) {
    if (new Date(values[i][0]).toDateString() === new Date(date).toDateString()) {
      sheet.getRange(i + 1, col).setValue(name);
      // 🔥 if updating TODAY → regenerate sets
      const today = new Date().toDateString();

      if (new Date(date).toDateString() === today) {

        const setsSheet = SpreadsheetApp.openById(SPREADSHEET_ID)
          .getSheetByName(SHEET_SETS);

        const all = setsSheet.getDataRange().getValues();

        // delete today's sets
        for (let i = all.length - 1; i >= 1; i--) {
          if (new Date(all[i][0]).toDateString() === today) {
            setsSheet.deleteRow(i + 1);
          }
        }

        handleGamesWeb(); // regenerate
      }
      return { success: true };
    }
  }

  return { error: "Date not found" };
}



