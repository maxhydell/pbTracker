function getPreviousHistoryEntry(data) {
  const sheet = SpreadsheetApp.openById(SPREADSHEET_ID)
    .getSheetByName("History");

  if (!sheet) return { winPct: 0, pointsAvg: 0 };

  const playerName = (data.name || "").trim().toLowerCase();
  const allRows = sheet.getDataRange().getValues();

  const today = new Date();
  today.setHours(0, 0, 0, 0);

  // Find all entries for this player that are NOT from today
  const playerEntries = [];
  for (let i = allRows.length - 1; i >= 1; i--) {
    const rowName = (allRows[i][1] || "").trim().toLowerCase();
    const rowDate = new Date(allRows[i][0]);
    rowDate.setHours(0, 0, 0, 0);

    if (rowName === playerName && rowDate.getTime() < today.getTime()) {
      playerEntries.push({
        date: rowDate,
        winPct: Number(allRows[i][2]) || 0,
        pointsAvg: Number(allRows[i][3]) || 0
      });
      // Only need the most recent previous entry
      break;
    }
  }

  if (playerEntries.length > 0) {
    return playerEntries[0];
  }

  return { winPct: 0, pointsAvg: 0 };
}


