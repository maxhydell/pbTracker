

// ===== MAIN API ENTRY =====
function doGet(e) {
  try {

    if (!e || !e.parameter) {
      Logger.log("❌ doGet called without parameters");
      return ContentService
        .createTextOutput(JSON.stringify({ error: "No parameters" }))
        .setMimeType(ContentService.MimeType.JSON);
    }

    const action = (e.parameter.action || "").trim();

    // 🔥 ADD THESE LOGS RIGHT HERE
    Logger.log("🔥 doGet HIT");
    Logger.log("ACTION:", action);
    Logger.log("PARAMS:", JSON.stringify(e.parameter));


    let result = {};

    if (action === "getAllData") {
       return ContentService.createTextOutput(
        JSON.stringify(getAllData())
      );
    }
    if (action === "getTodaySets") {
      ensureTodayGames();
      result = getTodaySets();
    }
    if (action === "lastUpdated") {
      const ss = SpreadsheetApp.openById(SPREADSHEET_ID);
      const sheet = ss.getSheetByName("Meta");

      if (!sheet) {
        return json({ error: "Meta sheet missing" });
      }

      return ContentService.createTextOutput(
        JSON.stringify(sheet.getRange("A1").getValue())
      );
    }
    else if (action === "saveSetFull") {
      result = saveSetFull(e.parameter);

      if (result && result.success) {
        updateLastUpdated();
      }
    }
    else if (action === "getUserTrend") result = getUserTrend();
    else if (action === "getSchedule") result = getSchedule();
    else if (action === "addPlayer") result = addPlayer(e.parameter);
    else if (action === "updateSchedule") result = updateSchedule(e.parameter);
    else if (action === "getPlayers") result = getPlayers();
    else if (action === "saveFullScheduleDay") result = saveFullScheduleDay(e.parameter);
    else if (action === "updateSchedulePartial") result = updateSchedulePartial(e.parameter);
    else if (action === "sendSaveNotification") result = sendSaveNotification();
    else if (action === "updatePlayerStatus") result = updatePlayerStatus(e.parameter);
    else if (action === "saveSharedResult") result = saveSharedResult(e.parameter);
    else if (action === "getSharedResult") result = getSharedResult(e.parameter);
    else if (action === "saveHistory") result = saveHistory();
    else if (action === "getHistory") result = getHistory();
    else if (action === "getPreviousHistoryEntry") result = getPreviousHistoryEntry(e.parameter);
    else if (action === "getAllSets") result = getAllSets();
    return ContentService
      .createTextOutput(JSON.stringify(result))
      .setMimeType(ContentService.MimeType.JSON);

  } catch (err) {
    return ContentService
      .createTextOutput(JSON.stringify({ error: err.toString() }))
      .setMimeType(ContentService.MimeType.JSON);
  }
}


function saveSetFull(data) {
    try {

  Logger.log("🔥 saveSetFull START");
Logger.log(JSON.stringify(data));
  const setNum = Number(data.set);
  const newScores = JSON.parse(data.scores || "[]");

  const ss = SpreadsheetApp.openById(SPREADSHEET_ID);
  const sheet = ss.getSheetByName("Sets");
  const rankingsSheet = ss.getSheetByName("Rankings");

  const all = sheet.getDataRange().getValues();

  const todayStr = new Date().toDateString();

  for (let i = 1; i < all.length; i++) {
    const rowDate = new Date(all[i][0]);
    if (isNaN(rowDate)) continue;

const rowDateStr = Utilities.formatDate(new Date(all[i][0]), ss.getSpreadsheetTimeZone(), "yyyy-MM-dd");
const todayDateStr = Utilities.formatDate(new Date(), ss.getSpreadsheetTimeZone(), "yyyy-MM-dd");

if (rowDateStr === todayDateStr && Number(all[i][1]) === setNum) {
      const teamA = all[i][2].split("/").map(p => p.trim());
      const teamB = all[i][3].split("/").map(p => p.trim());

      const changes = {};

      // helper
      function addChange(player, wins, points, games) {
        const key = player.toLowerCase();

        if (!changes[key]) {
          changes[key] = { wins: 0, points: 0, games: 0 };
        }

        changes[key].wins += wins;
        changes[key].points += points;
        changes[key].games += games;
      }

      // 🔥 LOOP ALL 3 GAMES
// 🔥 GET FULL ROW ONCE
const rowValues = sheet.getRange(i + 1, 1, 1, sheet.getLastColumn()).getValues()[0];

// 🔥 LOOP ALL 3 GAMES
// 🔥 LOOP ALL GAMES (supports Game 4+)
for (let g = 0; g < newScores.length; g++) {

  const oldScore = rowValues[4 + g] || "";
  const newScore = newScores[g] || "";

  // only update if changed
  if (oldScore !== newScore) {
    rowValues[4 + g] = newScore;
  }


  // REMOVE old
  if (oldScore && oldScore.includes("-")) {
    const [aOld, bOld] = oldScore.split("-").map(Number);
    const aWon = aOld > bOld;

    teamA.forEach(p => addChange(p, aWon ? -1 : 0, -aOld, -1));
    teamB.forEach(p => addChange(p, !aWon ? -1 : 0, -bOld, -1));
  }

  // ADD new
  if (newScore && newScore.includes("-")) {
    const [aNew, bNew] = newScore.split("-").map(Number);
    const aWon = aNew > bNew;

    teamA.forEach(p => addChange(p, aWon ? 1 : 0, aNew, 1));
    teamB.forEach(p => addChange(p, !aWon ? 1 : 0, bNew, 1));
  }

  // ✅ UPDATE IN MEMORY
  rowValues[4 + g] = newScore;
}

// 🔥 ONE WRITE ONLY
sheet.getRange(i + 1, 1, 1, rowValues.length).setValues([rowValues]);

// 🔥 APPLY BATCH UPDATES TO RANKINGS
const rData = rankingsSheet.getDataRange().getValues();

let redFlags = [];

Object.keys(changes).forEach(playerKey => {
  const change = changes[playerKey];

  for (let r = 1; r < rData.length; r++) {
    const name = (rData[r][0] || "").toLowerCase();

    if (name === playerKey) {

      const currentWins = Number(rData[r][3]) || 0;
      const currentPoints = Number(rData[r][4]) || 0;
      const currentGames = Number(rData[r][5]) || 0;

      const newWins = currentWins + change.wins;
      const newPoints = currentPoints + change.points;
      const newGames = currentGames + change.games;

      // 🚨 RED FLAG CHECK
if (
  newWins < 0 ||
  newPoints < 0 ||
  newGames < 0
) {
  redFlags.push(playerKey);
}

      // ✅ APPLY IN MEMORY (NOT SHEET)
      rData[r][3] = Math.max(0, newWins);
      rData[r][4] = Math.max(0, newPoints);
      rData[r][5] = Math.max(0, newGames);

      break;
    }
  }
});

// 🚨 STOP if bad data (BEFORE writing)
if (redFlags.length > 0) {
  Logger.log("🚨 RED FLAG PLAYERS: " + redFlags.join(", "));
  return {
    error: "Ranking inconsistency detected",
    players: redFlags
  };
}

// 🔥 ONE WRITE ONLY (THIS FIXES YOUR LAG)
rankingsSheet
  .getRange(1, 1, rData.length, rData[0].length)
  .setValues(rData);

      // ===== UPDATE I–L =====
      const players = [...teamA, ...teamB];

      const totals = {};
      players.forEach(p => totals[p] = { wins: 0, points: 0 });

      newScores.forEach(s => {
        if (!s || !s.includes("-")) return;

        const [a, b] = s.split("-").map(Number);

        teamA.forEach(p => {
          totals[p].points += a;
          if (a > b) totals[p].wins++;
        });

        teamB.forEach(p => {
          totals[p].points += b;
          if (b > a) totals[p].wins++;
        });
      });

      sheet.getRange(1, 9, 1, 4).setValues([players]);
      sheet.getRange(2, 9, 1, 4)
           .setValues([players.map(p => totals[p].wins)]);
      sheet.getRange(3, 9, 1, 4)
           .setValues([players.map(p => totals[p].points)]);

      return { success: true };
    }
  }

  return { success: false, debug: "Reached end unexpectedly" };


  } catch (err) {
    Logger.log("❌ ERROR: " + err.toString());
    return { error: err.toString() };
  }
}



function saveFullScheduleDay(data) {
  const sheet = SpreadsheetApp
    .openById(SPREADSHEET_ID)
    .getSheetByName("Schedule");

  const all = sheet.getDataRange().getValues();

  const parts = data.date.split("/");
  const incomingDate = new Date(
    Number(parts[2]), // year
    Number(parts[0]) - 1, // month (0-based)
    Number(parts[1]) // day
  );
  incomingDate.setHours(0,0,0,0);

  Logger.log("🔥 SAVE CALLED");
  Logger.log("Incoming date: " + data.date);

  // 🔍 TRY TO FIND EXISTING ROW
  for (let i = 1; i < all.length; i++) {
    const rowDate = new Date(all[i][0]);
    if (isNaN(rowDate)) continue;
    rowDate.setHours(0,0,0,0);

    if (rowDate.getTime() === incomingDate.getTime()) {
      Logger.log("✅ MATCH FOUND at row " + (i + 1));

const existingRow = all[i];

sheet.getRange(i + 1, 1, 1, 11).setValues([[
  data.date,
  Number(data.day),

  data.p1 !== undefined ? data.p1 : existingRow[2],
  data.p2 !== undefined ? data.p2 : existingRow[3],
  data.p3 !== undefined ? data.p3 : existingRow[4],
  data.p4 !== undefined ? data.p4 : existingRow[5],

  "",

  data.s1 !== undefined ? Number(data.s1) : existingRow[7],
  data.s2 !== undefined ? Number(data.s2) : existingRow[8],
  data.s3 !== undefined ? Number(data.s3) : existingRow[9],
  data.s4 !== undefined ? Number(data.s4) : existingRow[10],
]]);

      return { success: true, updated: true };
    }
  }

  // ❗ IF NOT FOUND → APPEND
  Logger.log("⚠️ NO MATCH — APPENDING NEW ROW");

  sheet.appendRow([
    data.date,
    Number(data.day),
    data.p1 || "",
    data.p2 || "",
    data.p3 || "",
    data.p4 || "",
    "",
    Number(data.s1) || 0,
    Number(data.s2) || 0,
    Number(data.s3) || 0,
    Number(data.s4) || 0
  ]);

  return { success: true, created: true };
}


