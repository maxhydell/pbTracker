// ===== FORMAT SCORE =====
function formatScore(r) {
  const scores = [r[4], r[5], r[6]].filter(s => s && s !== "");
  if (scores.length === 0) return "";
  return scores.join(" ");
}

// ===== SUBMIT SCORE (LIVE UPDATE) =====
function submitScore(data) {
  let debug = [];
  debug.push("submitScore called");
  debug.push(JSON.stringify(data));
  
  const setNum = Number(data.set);
  const game = Number(data.game); // 1,2,3
  const score = data.score;


  if (!score || !score.includes("-")) {
    Logger.log("❌ Invalid score format:", score);
    return { error: "Invalid score" };
  }

  const parts = score.split("-");
  if (parts.length !== 2 || parts[0] === "" || parts[1] === "") {
    Logger.log("❌ Incomplete score (skipping):", score);
    return { success: true };
  }


  Logger.log("=== SUBMIT SCORE START ===");
  Logger.log({ setNum, game, score });


  const ss = SpreadsheetApp.openById(SPREADSHEET_ID);

  const sheet = ss.getSheetByName(SHEET_SETS);
  const rankingsSheet = ss.getSheetByName("Rankings");

  if (!sheet) {
    Logger.log("❌ Sets sheet not found: " + SHEET_SETS);
  return { error: "Sets sheet missing" };
  }

  if (!rankingsSheet) {
    Logger.log("❌ Rankings sheet not found");
    return { error: "Rankings sheet missing" };
  }

const all = sheet.getDataRange().getValues();

const todayStr = new Date().toDateString(); // 🔥 SAME AS WORKING FUNCTION

for (let i = 1; i < all.length; i++) {
  const rowDate = new Date(all[i][0]);
  if (isNaN(rowDate)) continue;

  // 🔥 EXACT MATCH LOGIC (handles timestamps like 4/14/2026 10:48:45)
  if (
    rowDate.toDateString() === todayStr &&
    Number(all[i][1]) === setNum
  ) {

      debug.push("MATCH FOUND row " + (i + 1));
      debug.push("TeamA: " + all[i][2]);
      debug.push("TeamB: " + all[i][3]);
      const col = 5 + (Number(game) === 0 ? 0 : Number(game) - 1);  // E=5, F=6, G=7

      const teamA = all[i][2].split("/").map(p => p.trim());
      const teamB = all[i][3].split("/").map(p => p.trim());

      const oldScore = sheet.getRange(i + 1, col).getValue();
      debug.push("Old score: " + oldScore);
      debug.push("New score: " + score);

      Logger.log(`Writing → Row ${i+1}, Set ${setNum}, Game ${game}, Col ${col}, Score ${score}`);

      // ===== REMOVE OLD SCORE EFFECT =====
      if (typeof oldScore === "string" && oldScore.includes("-")) {
        const [oldA, oldB] = oldScore.split("-").map(Number);
        const oldWinnerA = oldA > oldB;

        teamA.forEach(p => {
          updatePlayerStats(p, oldWinnerA ? -1 : 0, -oldA, -1);
        });

        teamB.forEach(p => {
          updatePlayerStats(p, !oldWinnerA ? -1 : 0, -oldB, -1);
        });
      }

      // ===== WRITE NEW SCORE =====
      sheet.getRange(i + 1, col).setNumberFormat("@STRING@");
      sheet.getRange(i + 1, col).setValue(score);
      const baseRow = i + 1;

      // ===== GET PLAYERS =====
      const players = [...teamA, ...teamB];

      // ===== WRITE NAMES (SET 1) =====
      if (setNum === 1) {
        sheet.getRange(baseRow, 9, 1, 4)
             .setValues([players]);
      }

      // ===== CALCULATE TOTALS =====
      const totals = {};
      players.forEach(p => {
        totals[p] = {
          wins: 0,
          points: 0
        };
      });

      

      // ===== LOOP ALL 3 GAMES =====
      for (let g = 0; g < 3; g++) {

        const s = sheet.getRange(i + 1, 5 + g).getValue();

        if (!s || !s.includes("-")) continue;

        const [aScore, bScore] = s.split("-").map(Number);

        teamA.forEach(p => {
          totals[p].points += aScore;

          if (aScore > bScore) {
            totals[p].wins++;
          }
        });

        teamB.forEach(p => {
          totals[p].points += bScore;

          if (bScore > aScore) {
            totals[p].wins++;
          }
        });
      }

      // ===== SET 2 → WINS =====
      if (setNum === 2) {

        sheet.getRange(baseRow, 8)
             .setValue("Wins");

        sheet.getRange(baseRow, 9, 1, 4)
             .setValues([
               players.map(p => totals[p].wins)
             ]);
      }

      // ===== SET 3 → POINTS =====
      if (setNum === 3) {

        sheet.getRange(baseRow, 8)
             .setValue("Points");

        sheet.getRange(baseRow, 9, 1, 4)
             .setValues([
               players.map(p => totals[p].points)
             ]);
      }     

      // ===== APPLY NEW SCORE =====
      const [a, b] = score.split("-").map(Number);
      const winnerA = a > b;

      teamA.forEach(p => {
        updatePlayerStats(p, winnerA ? 1 : 0, a, 1);
      });

      teamB.forEach(p => {
        updatePlayerStats(p, !winnerA ? 1 : 0, b, 1);
      });

      return { success: true, debug };
    }
  }

  Logger.log("Writing score:", setNum, game, score);
  Logger.log("❌ NO MATCH FOUND for set: " + setNum);
  return { error: "Set not found", debug };
}

function updatePlayerStatus(data) {
  const sheet = SpreadsheetApp.openById(SPREADSHEET_ID)
    .getSheetByName("Schedule");

  const date = new Date(data.date);
  date.setHours(0,0,0,0);
  const col = Number(data.col); // 1–4
  const status = Number(data.status); // 1 or 2

  const values = sheet.getDataRange().getValues();

  for (let i = 1; i < values.length; i++) {
    const d = new Date(values[i][0]);
    d.setHours(0,0,0,0);

    if (d.getTime() === date.getTime()) {
      const sheetCol = 6 + col; // G–J
      if (sheetCol < 7 || sheetCol > 10) return { error: "Invalid col" };

      sheet.getRange(i + 1, sheetCol).setValue(status);
      return { success: true };
    }
  }

  return { error: "not found" };
}



