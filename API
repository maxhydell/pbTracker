function generateGamesFromSchedule() {
  const ss = SpreadsheetApp.openById(SPREADSHEET_ID);

  const schedule = ss.getSheetByName("Schedule");
  const sets = ss.getSheetByName("Sets");

  const data = schedule.getDataRange().getValues();

  const today = new Date();
  const todayStr = today.toDateString();

  const todayRow = data.find(r => {
    const d = new Date(r[0]);
    d.setHours(0,0,0,0);
    return d.getTime() === today.getTime();
  });

  if (!todayRow) return;

  const players = todayRow.slice(2, 6).filter(Boolean);

  if (players.length < 4) return;

  // Simple pairing (can upgrade later)
  const pairs = [
    [players[0], players[1], players[2], players[3]],
    [players[0], players[2], players[1], players[3]],
    [players[0], players[3], players[1], players[2]]
  ];

const existing = sets.getDataRange().getValues();

pairs.forEach((p, i) => {

  const alreadyExists = existing.some(r => {
    const d = new Date(r[0]);
    d.setHours(0,0,0,0);

    const today = new Date();
    today.setHours(0,0,0,0);

    return (
      d.getTime() === today.getTime() &&
      Number(r[1]) === (i + 1)
    );
  });

  if (alreadyExists) return; // 🚫 STOP DUPLICATE
// flag
  sets.appendRow([
    today,
    i + 1,
    `${p[0]} / ${p[1]}`,
    `${p[2]} / ${p[3]}`,
    "", "", ""
  ]);
});
}




function updateSchedulePartial(data) {
  const sheet = SpreadsheetApp
    .openById(SPREADSHEET_ID)
    .getSheetByName("Schedule");

  const all = sheet.getDataRange().getValues();
  const changes = JSON.parse(data.changes || "[]");

  const parts = data.date.split("/");
  const incomingDate = new Date(
    Number(parts[2]),
    Number(parts[0]) - 1,
    Number(parts[1])
  );
  incomingDate.setHours(0, 0, 0, 0);

  const dayNum = incomingDate.getDay() === 0 ? 7 : incomingDate.getDay(); // Mon=1

  Logger.log("🔥 PARTIAL UPDATE");
  Logger.log("Date: " + data.date);

  let targetRow = -1;

  // 🔍 FIND EXISTING ROW
  for (let i = 1; i < all.length; i++) {
    const rowDate = new Date(all[i][0]);
    if (isNaN(rowDate)) continue;

    rowDate.setHours(0, 0, 0, 0);

    if (rowDate.getTime() === incomingDate.getTime()) {
      targetRow = i + 1;
      break;
    }
  }

  // ❗ IF NOT FOUND → CREATE AT CORRECT POSITION
  if (targetRow === -1) {
    Logger.log("⚠️ Creating new row");

    // Find correct position (Mon–Fri order)
    let insertIndex = 2; // default after header

    for (let i = 1; i < all.length; i++) {
      const rowDay = Number(all[i][1]) || 0;

      if (rowDay > dayNum) {
        insertIndex = i + 1;
        break;
      }

      insertIndex = i + 2;
    }

    sheet.insertRowBefore(insertIndex);

    sheet.getRange(insertIndex, 1, 1, 11).setValues([[
      data.date,
      dayNum,
      "", "", "", "",
      "",
      0, 0, 0, 0
    ]]);

    targetRow = insertIndex;
  }

  // 🔥 column mapping
  const colMap = {
    p1: 3, p2: 4, p3: 5, p4: 6,
    s1: 8, s2: 9, s3: 10, s4: 11
  };

  // 🔥 APPLY CHANGES
  changes.forEach(change => {
    const col = colMap[change.field];
    if (!col) return;

    const val =
      typeof change.value === "string"
        ? change.value.toLowerCase()
        : change.value;

    sheet.getRange(targetRow, col).setValue(val);
  });

  return { success: true };
}





function handleGamesWeb() {
  const ss = SpreadsheetApp.openById(SPREADSHEET_ID);

  const scheduleSheet = ss.getSheetByName(SHEET_SCHEDULE);
  const setsSheet = ss.getSheetByName(SHEET_SETS);

  if (!scheduleSheet || !setsSheet) {
    Logger.log("❌ Missing schedule or sets sheet");
    return;
  }


  const todayStr = new Date().toDateString();
  const scheduleData = scheduleSheet.getDataRange().getValues();

  let players = null;

  for (let i = 1; i < scheduleData.length; i++) {
    if (new Date(scheduleData[i][0]).toDateString() === todayStr) {
      players = scheduleData[i].slice(2, 6);
      break;
    }
  }

  if (!players || players.length < 4) return;

  // 🚨 prevent duplicates
  const existing = setsSheet.getDataRange().getValues().some(r =>
    new Date(r[0]).toDateString() === todayStr
  );

  if (existing) return;

  const now = Utilities.formatDate(
    new Date(),
    Session.getScriptTimeZone(),
    "M/d/yyyy H:mm:ss"
  );

  const rows = [
    [now, 1, `${players[0]} / ${players[1]}`, `${players[2]} / ${players[3]}`, "", "", ""],
    [now, 2, `${players[0]} / ${players[3]}`, `${players[2]} / ${players[1]}`, "", "", ""],
    [now, 3, `${players[0]} / ${players[2]}`, `${players[3]} / ${players[1]}`, "", "", ""]
  ];

  const startRow = setsSheet.getLastRow() + 1;

  setsSheet.getRange(startRow, 1, rows.length, rows[0].length)
    .setValues(rows);
}

